{
  "name": "ledger-dashboard",
  "description": "Ledger — a swappable dashboard theme starter: React, TypeScript, Tailwind v4, ~100 token-only components, re-skinnable from one folder.",
  "license": "MIT",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
