{
  "extends": "../tsconfig.app.json",
  "compilerOptions": {
    "composite": false,
    "incremental": false,
    "noEmit": false,
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "../dist/types",
    "rootDir": "../src",
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "skipLibCheck": true,
    "types": ["react", "react-dom", "node"]
  },
  "include": ["../src"],
  "exclude": ["../src/**/*.test.ts", "../src/**/*.test.tsx", "../src/**/*.spec.ts", "../src/**/*.spec.tsx", "../src/test-setup.ts"]
}
